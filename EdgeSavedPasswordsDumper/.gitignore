###############################################
# .gitignore for C# / .NET Projects
# With explanations for each section
###############################################

###############
# Build Output
###############
# These folders contain compiled binaries and temporary build files.
# They should never be committed.
bin/
obj/
[Bb]uild/
[Ll]og/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

########################
# Visual Studio Artifacts
########################
# IDE-specific files that store user preferences, caches, and metadata.
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

########################
# NuGet Packages
########################
# NuGet restores packages automatically; no need to commit them.
packages/
*.nupkg
*.snupkg
.nuget/
project.lock.json
project.assets.json

########################
# MSBuild Files
########################
# Intermediate build caches and logs.
*.cache
*.db
*.log
*.tlog

########################
# Rider / ReSharper
########################
# JetBrains IDE metadata and caches.
_ReSharper*/
*.DotSettings.user
.idea/

########################
# Test Results
########################
# Output from test runs — large, auto-generated, and not needed in Git.
TestResult*/
TestResults/
*.trx
*.coverage
*.coveragexml

########################
# Temporary / Backup Files
########################
# Common temp files created by editors or tools.
*.tmp
*.temp
*.bak
*.old

########################
# Auto-Generated Code
########################
# Files generated at build time (WPF, WinForms, etc.).
Generated\ Files/
*.g.cs
*.g.i.cs

########################
# Publish Output
########################
# Files created when publishing a project.
publish/
*.pubxml
*.publishsettings

########################
# Profiling / Debugging Tools
########################
*.psess
*.vsp
*.vspscc
*.vssscc

########################
# OS-Specific Files
########################

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store
